# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

region = "us-east-1"

vpc_id   = "vpc-0123456789abcdef0"
vpc_cidrs = [
  "10.0.0.0/16",   # primary VPC CIDR
  "10.1.0.0/16",   # secondary VPC CIDR
]

private_subnet_ids = [
  "subnet-aaaa1111aaaa1111a", # private subnet — AZ 1
  "subnet-bbbb2222bbbb2222b", # private subnet — AZ 2
]

ami_id        = "ami-your-custom-rhel-id"
instance_type = "t3.medium"

# S3 artifact bucket — choose one of the two options below:
#
# Option A: Let the module create and manage the bucket (recommended).
#   terraform apply, then upload the artifact:
#     tar -czf ui_module.tar.gz -C . ui_module/ requirements.txt
#     aws s3 cp ui_module.tar.gz s3://$(terraform output -raw app_s3_bucket_name)/ui_module/ui_module.tar.gz
create_app_s3_bucket = true

# Option B: Bring your own bucket (set create_app_s3_bucket = false).
# app_s3_bucket = "my-existing-bucket"

app_s3_key = "ui_module/ui_module.tar.gz"

agent_api_base_url  = "https://abc123def4.execute-api.us-east-1.amazonaws.com/prod"
agent_api_auth_mode = "iam"

create_execute_api_vpce = true

tags = {
  Environment = "dev"
  Project     = "chatbot-ui"
}
